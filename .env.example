# Application Config
APP_NAME="Hotel Booking AI Assistant"
APP_HOST="0.0.0.0"
APP_PORT=8000
LOG_LEVEL="INFO"

# LLM Config (Ollama for local, or update to OpenAI/Anthropic if deploying to cloud)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1:8b"
CONFIDENCE_THRESHOLD=0.65

# Database Config (Replace with Railway PostgreSQL URL for production)
# Example: postgresql+asyncpg://postgres:password@host:port/dbname
DATABASE_URL="sqlite+aiosqlite:///./hotel_booking.db"

# Optional: Redis URL for task queues or websocket pub/sub
# REDIS_URL="redis://default:password@host:port"
