# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_NAME="Hotel Booking AI Assistant"
APP_HOST="0.0.0.0"
APP_PORT=8000
LOG_LEVEL="INFO"

# ─────────────────────────────────────────────
# LLM (Ollama local / swap for OpenAI in prod)
# ─────────────────────────────────────────────
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1:8b"
CONFIDENCE_THRESHOLD=0.65

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_USER="hotelmind"
POSTGRES_PASSWORD="hotelmind_secret"
POSTGRES_DB="hotelmind"
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432

# Full async URL consumed by SQLAlchemy & Alembic
# For Railway: postgresql+asyncpg://user:pass@host:port/db
DATABASE_URL="postgresql+asyncpg://hotelmind:hotelmind_secret@localhost:5432/hotelmind"

# ─────────────────────────────────────────────
# ChromaDB
# ─────────────────────────────────────────────
CHROMA_PERSIST_DIR="./chroma_db"
SENTENCE_TRANSFORMER_MODEL="all-MiniLM-L6-v2"

# ─────────────────────────────────────────────
# Optional: Redis (task queues / WS pub-sub)
# ─────────────────────────────────────────────
# REDIS_URL="redis://default:password@host:6379"
